{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "username": "anokfireball",
  "plugin": [
    // dynamic context pruning
    "@tarquinen/opencode-dcp@latest",
    // terminal emulation for tools that require interactive sessions
    "opencode-pty",
    // background process management
    "@zenobius/opencode-background"
  ],
  "small_model": "{env:OPENCODE_MODEL_SMALL}",
  "default_agent": "research",
  "agent": {
    // Built-in agents — model overrides only; no permission overrides for build/general
    "build": {
      "model": "{env:OPENCODE_MODEL_BUILD}"
    },
    "plan": {
      "model": "{env:OPENCODE_MODEL_PLAN}",
      // Upstream already restricts edit/bash to ask. Gate infra/writing MCPs.
      "permission": {
        "kubernetes_*": "ask",
        "obsidian_*": "ask",
        "drawio_*": "ask"
      }
    },
    "general": {
      "model": "{env:OPENCODE_MODEL_GENERAL}"
    },
    "explore": {
      "model": "{env:OPENCODE_MODEL_EXPLORE}",
      // Already read-only upstream. Deny MCPs irrelevant to fast recon.
      "permission": {
        "kubernetes_*": "deny",
        "obsidian_*": "deny",
        "drawio_*": "deny",
        "sequentialthinking_*": "deny"
      }
    },
    "compaction": {
      "model": "{env:OPENCODE_MODEL_COMPACTION}"
    },
    "title": {
      "model": "{env:OPENCODE_MODEL_TITLE}"
    },
    "summary": {
      "model": "{env:OPENCODE_MODEL_SUMMARY}"
    },
    "research": {
      "description": "Performs comprehensive research and analysis to answer questions about code, tools, frameworks, and project structure",
      "model": "{env:OPENCODE_MODEL_RESEARCH}",
      "mode": "primary",
      "temperature": 0.0,
      "permission": {
        // Read access — all allowed
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "codesearch": "allow",
        // Mutations — hard deny
        "edit": "deny",
        // Bash — safety valve (git MCP covers read-only git needs)
        "bash": "ask",
        // Agent orchestration
        "task": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "question": "allow",
        // Web access — allow (research needs docs, links, external sources)
        "webfetch": "allow",
        "websearch": "allow",
        // External dirs — ask
        "external_directory": "ask",
        "doom_loop": "ask",
        // MCPs — broad read access, gate infra
        "context7_*": "allow",
        "octocode_*": "allow",
        "git_*": "allow",
        "filesystem_*": "allow",
        "sequentialthinking_*": "allow",
        "obsidian_*": "allow",
        "kubernetes_*": "ask",
        "drawio_*": "deny"
      },
      "prompt": "{file:./prompts/research.txt}"
    },
    "review": {
      "description": "Performs in-depth code reviews focusing on correctness, security, maintainability, and architecture",
      "model": "{env:OPENCODE_MODEL_REVIEW}",
      "mode": "primary",
      "temperature": 0.1,
      "permission": {
        // Read access — all allowed
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "codesearch": "allow",
        // Mutations — hard deny
        "edit": "deny",
        // Bash — safety valve (git MCP covers read-only git needs)
        "bash": "ask",
        // Agent orchestration
        "task": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "question": "allow",
        // Web access — allow (review needs to look up docs, RFCs, CVEs)
        "webfetch": "allow",
        "websearch": "allow",
        // External dirs — ask
        "external_directory": "ask",
        "doom_loop": "ask",
        // MCPs — code-focused only; no obsidian/kubernetes/drawio
        "context7_*": "allow",
        "octocode_*": "allow",
        "git_*": "allow",
        "filesystem_*": "allow",
        "sequentialthinking_*": "allow",
        "obsidian_*": "deny",
        "kubernetes_*": "deny",
        "drawio_*": "deny"
      },
      "prompt": "{file:./prompts/review.txt}"
    },
    "ticket": {
      "description": "Generates well-structured ticket files from scenario descriptions and tasks",
      "model": "{env:OPENCODE_MODEL_TICKET}",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": {
        // Read access — allowed for code context
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "codesearch": "allow",
        // Writes — ask (ticket files only)
        "edit": "ask",
        // No shell needs
        "bash": "deny",
        // No subagent chaining or skills
        "task": "deny",
        "skill": "deny",
        "todowrite": "allow",
        "question": "allow",
        // Web — ask only (may need to reference issue URLs)
        "webfetch": "ask",
        "websearch": "deny",
        "external_directory": "deny",
        "doom_loop": "deny",
        // MCPs — obsidian only (ticket storage)
        "obsidian_*": "allow",
        "context7_*": "deny",
        "octocode_*": "deny",
        "kubernetes_*": "deny",
        "drawio_*": "deny",
        "git_*": "deny",
        "filesystem_*": "deny",
        "sequentialthinking_*": "deny"
      },
      "prompt": "{file:./prompts/ticket.txt}"
    },
    "docs": {
      "description": "Creates comprehensive documentation including inline code comments, API docs, and architectural overviews",
      "model": "{env:OPENCODE_MODEL_DOCS}",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": {
        // Read access — allowed for code context
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "codesearch": "allow",
        // Writes — ask (doc files)
        "edit": "ask",
        // Bash — mkdir for doc dirs, rest ask
        "bash": {
          "mkdir*": "allow",
          "*": "ask"
        },
        // No subagent chaining or skills
        "task": "deny",
        "skill": "deny",
        "todowrite": "allow",
        "question": "allow",
        // Web — ask (may need external API docs)
        "webfetch": "ask",
        "websearch": "ask",
        "external_directory": "deny",
        "doom_loop": "deny",
        // MCPs — docs toolchain only
        "context7_*": "allow",
        "obsidian_*": "allow",
        "drawio_*": "allow",
        "filesystem_*": "allow",
        "octocode_*": "deny",
        "kubernetes_*": "deny",
        "git_*": "deny",
        "sequentialthinking_*": "deny"
      },
      "prompt": "{file:./prompts/docs.txt}"
    },
    "test": {
      "description": "Analyzes codebases to design appropriate test strategies, reasons about test necessity and type selection, and implements comprehensive test suites following language-specific best practices",
      "model": "{env:OPENCODE_MODEL_TEST}",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": {
        // Read access — allowed for code context
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "codesearch": "allow",
        // Writes — ask (test files)
        "edit": "ask",
        // Bash — test runners + mkdir explicitly allowed
        "bash": {
          "npm test*": "allow",
          "npx jest*": "allow",
          "npx vitest*": "allow",
          "pytest*": "allow",
          "go test*": "allow",
          "make test*": "allow",
          "mkdir*": "allow",
          "*": "ask"
        },
        // No subagent chaining or skills
        "task": "deny",
        "skill": "deny",
        "todowrite": "allow",
        "question": "allow",
        // Web — ask (may need test framework docs)
        "webfetch": "ask",
        "websearch": "deny",
        "external_directory": "deny",
        "doom_loop": "deny",
        // MCPs — test toolchain only
        "context7_*": "allow",
        "filesystem_*": "allow",
        "octocode_*": "deny",
        "kubernetes_*": "deny",
        "obsidian_*": "deny",
        "drawio_*": "deny",
        "git_*": "deny",
        "sequentialthinking_*": "deny"
      },
      "prompt": "{file:./prompts/test.txt}"
    }
  },
  "disabled_providers": ["opencode"],
  "provider": {
    "github-copilot": {
      "blacklist": [
        // Officially retired models
        // Reference: https://docs.github.com/en/copilot/reference/ai-models/supported-models#model-retirement-history
        "gpt-4o", // not in current supported models list
        "gpt-5", // retired 2026-02-17
        "gpt-5.1", // closing down 2026-04-15
        "gpt-5.1-codex", // retired 2026-04-01
        "gpt-5.1-codex-max", // retired 2026-04-01
        "gpt-5.1-codex-mini", // retired 2026-04-01
        "gemini-3-pro-preview", // retired 2026-03-26
        "claude-opus-41", // retired 2026-02-17
        // Personal preference for "superseeded" models
        "claude-sonnet-4", // older Sonnet version
        "claude-sonnet-4.5", // older Sonnet version
        "claude-opus-4.5", // older Opus version
        "gpt-5.2", // older GPT-5 generation
        "gpt-5.2-codex" // older Codex variant
      ]
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "--prefer-offline", "@upstash/context7-mcp"],
      "enabled": true
    },
    "kubernetes": {
      "type": "local",
      "command": ["npx", "--prefer-offline", "kubernetes-mcp-server"],
      "enabled": true,
      "environment": {
        "KUBECONFIG": "{env:KUBECONFIG}"
      }
    },
    "obsidian": {
      "type": "local",
      "command": [
        "npx",
        "@bitbonsai/mcpvault@latest",
        "{env:HOME}/Documents/Obsidian Vault"
      ],
      "enabled": true
    },
    "drawio": {
      "type": "local",
      "command": ["npx", "--prefer-offline", "@drawio/mcp"],
      "enabled": true
    },
    "octocode": {
      "type": "local",
      "command": ["npx", "--prefer-offline", "octocode-mcp"],
      "enabled": true
    },
    "git": {
      "type": "local",
      "command": ["uvx", "mcp-server-git", "--repository", "."],
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "."],
      "enabled": true
    },
    "sequentialthinking": {
      "type": "local",
      "command": [
        "npx",
        "--prefer-offline",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    }
  }
}
