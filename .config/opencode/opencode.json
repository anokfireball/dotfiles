{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "username": "anokfireball",
  "plugin": [
    // dynamic context pruning
    "@tarquinen/opencode-dcp@latest",
    // terminal emulation for tools that require interactive sessions
    "opencode-pty",
    // background process management
    "@zenobius/opencode-background"
  ],
  "small_model": "{env:OPENCODE_MODEL_SMALL}",
  "default_agent": "research",
  "agent": {
    // Built-in agents — model overrides only; no permission overrides for build/general
    "build": {
      "model": "{env:OPENCODE_MODEL_BUILD}"
    },
    "plan": {
      "model": "{env:OPENCODE_MODEL_PLAN}",
      // Upstream already restricts edit/bash to ask. Fine-grained MCP gates.
      "permission": {
        "git_*": "ask",
        "filesystem_*": "ask",
        "obsidian_*": "ask",
        // Kubernetes — read-only auto-allow, mutations ask
        "kubernetes_*": "deny",
        "kubernetes_pods_list": "allow",
        "kubernetes_pods_list_in_namespace": "allow",
        "kubernetes_pods_get": "allow",
        "kubernetes_pods_top": "allow",
        "kubernetes_pods_log": "allow",
        "kubernetes_events_list": "allow",
        "kubernetes_namespaces_list": "allow",
        "kubernetes_nodes_log": "allow",
        "kubernetes_resources_list": "allow",
        "kubernetes_pods_delete": "ask",
        "kubernetes_pods_exec": "ask",
        "kubernetes_pods_run": "ask",
        "kubernetes_resources_create_or_update": "ask",
        "kubernetes_resources_delete": "ask",
        "drawio_*": "ask"
      }
    },
    "general": {
      "model": "{env:OPENCODE_MODEL_GENERAL}"
    },
    "explore": {
      "model": "{env:OPENCODE_MODEL_EXPLORE}",
      // Already read-only upstream. Fine-grained read access to MCPs.
      "permission": {
        // Kubernetes — read-only recon
        "kubernetes_*": "deny",
        "kubernetes_pods_list": "allow",
        "kubernetes_pods_list_in_namespace": "allow",
        "kubernetes_pods_get": "allow",
        "kubernetes_pods_top": "allow",
        "kubernetes_pods_log": "allow",
        "kubernetes_events_list": "allow",
        "kubernetes_namespaces_list": "allow",
        "kubernetes_nodes_log": "allow",
        "kubernetes_resources_list": "allow",
        // Git — read-only
        "git_*": "deny",
        "git_status": "allow",
        "git_diff_unstaged": "allow",
        "git_diff_staged": "allow",
        "git_diff": "allow",
        "git_log": "allow",
        "git_show": "allow",
        "git_branch": "allow",
        // Filesystem — read-only
        "filesystem_*": "deny",
        "filesystem_read_file": "allow",
        "filesystem_read_text_file": "allow",
        "filesystem_read_media_file": "allow",
        "filesystem_read_multiple_files": "allow",
        "filesystem_list_directory": "allow",
        "filesystem_list_directory_with_sizes": "allow",
        "filesystem_directory_tree": "allow",
        "filesystem_search_files": "allow",
        "filesystem_get_file_info": "allow",
        "filesystem_list_allowed_directories": "allow",
        // Not needed for fast recon
        "obsidian_*": "deny",
        "drawio_*": "deny",
        "sequentialthinking_*": "deny"
      }
    },
    "compaction": {
      "model": "{env:OPENCODE_MODEL_COMPACTION}"
    },
    "title": {
      "model": "{env:OPENCODE_MODEL_TITLE}"
    },
    "summary": {
      "model": "{env:OPENCODE_MODEL_SUMMARY}"
    },
    "research": {
      "description": "Performs comprehensive research and analysis to answer questions about code, tools, frameworks, and project structure",
      "model": "{env:OPENCODE_MODEL_RESEARCH}",
      "mode": "primary",
      "temperature": 0.0,
      "permission": {
        // Read access — all allowed
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "codesearch": "allow",
        // Mutations — hard deny
        "edit": "deny",
        // Bash — safety valve
        "bash": "ask",
        // Agent orchestration
        "task": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "question": "allow",
        // Web access
        "webfetch": "allow",
        "websearch": "allow",
        // External dirs
        "external_directory": "ask",
        "doom_loop": "ask",
        // MCPs — safe blanket allows
        "context7_*": "allow",
        "octocode_*": "allow",
        "sequentialthinking_*": "allow",
        // Git — read-only (deny catch-all, then allowlist)
        "git_*": "deny",
        "git_status": "allow",
        "git_diff_unstaged": "allow",
        "git_diff_staged": "allow",
        "git_diff": "allow",
        "git_log": "allow",
        "git_show": "allow",
        "git_branch": "allow",
        // Filesystem — read-only
        "filesystem_*": "deny",
        "filesystem_read_file": "allow",
        "filesystem_read_text_file": "allow",
        "filesystem_read_media_file": "allow",
        "filesystem_read_multiple_files": "allow",
        "filesystem_list_directory": "allow",
        "filesystem_list_directory_with_sizes": "allow",
        "filesystem_directory_tree": "allow",
        "filesystem_search_files": "allow",
        "filesystem_get_file_info": "allow",
        "filesystem_list_allowed_directories": "allow",
        // Obsidian — read-only
        "obsidian_*": "deny",
        "obsidian_read_note": "allow",
        "obsidian_list_directory": "allow",
        "obsidian_search_notes": "allow",
        "obsidian_read_multiple_notes": "allow",
        "obsidian_get_notes_info": "allow",
        "obsidian_get_frontmatter": "allow",
        "obsidian_get_vault_stats": "allow",
        "obsidian_list_all_tags": "allow",
        // Kubernetes — read-only
        "kubernetes_*": "deny",
        "kubernetes_pods_list": "allow",
        "kubernetes_pods_list_in_namespace": "allow",
        "kubernetes_pods_get": "allow",
        "kubernetes_pods_top": "allow",
        "kubernetes_pods_log": "allow",
        "kubernetes_events_list": "allow",
        "kubernetes_namespaces_list": "allow",
        "kubernetes_nodes_log": "allow",
        "kubernetes_resources_list": "allow",
        "drawio_*": "deny"
      },
      "prompt": "{file:./prompts/research.txt}"
    },
    "review": {
      "description": "Performs in-depth code reviews focusing on correctness, security, maintainability, and architecture",
      "model": "{env:OPENCODE_MODEL_REVIEW}",
      "mode": "primary",
      "temperature": 0.1,
      "permission": {
        // Read access — all allowed
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "codesearch": "allow",
        // Mutations — hard deny
        "edit": "deny",
        // Bash — safety valve
        "bash": "ask",
        // Agent orchestration
        "task": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "question": "allow",
        // Web access
        "webfetch": "allow",
        "websearch": "allow",
        // External dirs
        "external_directory": "ask",
        "doom_loop": "ask",
        // MCPs — safe blanket allows
        "context7_*": "allow",
        "octocode_*": "allow",
        "sequentialthinking_*": "allow",
        // Git — read-only
        "git_*": "deny",
        "git_status": "allow",
        "git_diff_unstaged": "allow",
        "git_diff_staged": "allow",
        "git_diff": "allow",
        "git_log": "allow",
        "git_show": "allow",
        "git_branch": "allow",
        // Filesystem — read-only
        "filesystem_*": "deny",
        "filesystem_read_file": "allow",
        "filesystem_read_text_file": "allow",
        "filesystem_read_media_file": "allow",
        "filesystem_read_multiple_files": "allow",
        "filesystem_list_directory": "allow",
        "filesystem_list_directory_with_sizes": "allow",
        "filesystem_directory_tree": "allow",
        "filesystem_search_files": "allow",
        "filesystem_get_file_info": "allow",
        "filesystem_list_allowed_directories": "allow",
        // No obsidian/kubernetes/drawio for code review
        "obsidian_*": "deny",
        "kubernetes_*": "deny",
        "drawio_*": "deny"
      },
      "prompt": "{file:./prompts/review.txt}"
    },
    "ticket": {
      "description": "Generates well-structured ticket files from scenario descriptions and tasks",
      "model": "{env:OPENCODE_MODEL_TICKET}",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": {
        // Read access — allowed for code context
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "codesearch": "allow",
        // Writes — ask (ticket files only)
        "edit": "ask",
        // No shell needs
        "bash": "deny",
        // No subagent chaining or skills
        "task": "deny",
        "skill": "deny",
        "todowrite": "allow",
        "question": "allow",
        // Web — ask only (may need to reference issue URLs)
        "webfetch": "ask",
        "websearch": "deny",
        "external_directory": "deny",
        "doom_loop": "deny",
        // Obsidian — read + controlled writes for ticket storage
        "obsidian_*": "deny",
        "obsidian_read_note": "allow",
        "obsidian_list_directory": "allow",
        "obsidian_search_notes": "allow",
        "obsidian_read_multiple_notes": "allow",
        "obsidian_get_notes_info": "allow",
        "obsidian_get_frontmatter": "allow",
        "obsidian_get_vault_stats": "allow",
        "obsidian_list_all_tags": "allow",
        "obsidian_write_note": "allow",
        "obsidian_patch_note": "allow",
        // Everything else denied
        "context7_*": "deny",
        "octocode_*": "deny",
        "kubernetes_*": "deny",
        "drawio_*": "deny",
        "git_*": "deny",
        "filesystem_*": "deny",
        "sequentialthinking_*": "deny"
      },
      "prompt": "{file:./prompts/ticket.txt}"
    },
    "docs": {
      "description": "Creates comprehensive documentation including inline code comments, API docs, and architectural overviews",
      "model": "{env:OPENCODE_MODEL_DOCS}",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": {
        // Read access — allowed for code context
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "codesearch": "allow",
        // Writes — ask (doc files)
        "edit": "ask",
        // Bash — mkdir for doc dirs, rest ask
        "bash": {
          "mkdir*": "allow",
          "*": "ask"
        },
        // No subagent chaining or skills
        "task": "deny",
        "skill": "deny",
        "todowrite": "allow",
        "question": "allow",
        // Web — ask (may need external API docs)
        "webfetch": "ask",
        "websearch": "ask",
        "external_directory": "deny",
        "doom_loop": "deny",
        // MCPs — docs toolchain
        "context7_*": "allow",
        "drawio_*": "allow",
        // Filesystem — read + controlled writes
        "filesystem_*": "deny",
        "filesystem_read_file": "allow",
        "filesystem_read_text_file": "allow",
        "filesystem_read_media_file": "allow",
        "filesystem_read_multiple_files": "allow",
        "filesystem_list_directory": "allow",
        "filesystem_list_directory_with_sizes": "allow",
        "filesystem_directory_tree": "allow",
        "filesystem_search_files": "allow",
        "filesystem_get_file_info": "allow",
        "filesystem_list_allowed_directories": "allow",
        "filesystem_write_file": "ask",
        "filesystem_edit_file": "ask",
        "filesystem_create_directory": "allow",
        // Obsidian — read + controlled writes
        "obsidian_*": "deny",
        "obsidian_read_note": "allow",
        "obsidian_list_directory": "allow",
        "obsidian_search_notes": "allow",
        "obsidian_read_multiple_notes": "allow",
        "obsidian_get_notes_info": "allow",
        "obsidian_get_frontmatter": "allow",
        "obsidian_get_vault_stats": "allow",
        "obsidian_list_all_tags": "allow",
        "obsidian_write_note": "allow",
        "obsidian_patch_note": "allow",
        "obsidian_update_frontmatter": "ask",
        // Rest denied
        "octocode_*": "deny",
        "kubernetes_*": "deny",
        "git_*": "deny",
        "sequentialthinking_*": "deny"
      },
      "prompt": "{file:./prompts/docs.txt}"
    },
    "test": {
      "description": "Analyzes codebases to design appropriate test strategies, reasons about test necessity and type selection, and implements comprehensive test suites following language-specific best practices",
      "model": "{env:OPENCODE_MODEL_TEST}",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": {
        // Read access — allowed for code context
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "codesearch": "allow",
        // Writes — ask (test files)
        "edit": "ask",
        // Bash — test runners + mkdir explicitly allowed
        "bash": {
          "npm test*": "allow",
          "npx jest*": "allow",
          "npx vitest*": "allow",
          "pytest*": "allow",
          "go test*": "allow",
          "make test*": "allow",
          "mkdir*": "allow",
          "*": "ask"
        },
        // No subagent chaining or skills
        "task": "deny",
        "skill": "deny",
        "todowrite": "allow",
        "question": "allow",
        // Web — ask (may need test framework docs)
        "webfetch": "ask",
        "websearch": "deny",
        "external_directory": "deny",
        "doom_loop": "deny",
        // MCPs — test toolchain
        "context7_*": "allow",
        // Filesystem — read + controlled writes
        "filesystem_*": "deny",
        "filesystem_read_file": "allow",
        "filesystem_read_text_file": "allow",
        "filesystem_read_media_file": "allow",
        "filesystem_read_multiple_files": "allow",
        "filesystem_list_directory": "allow",
        "filesystem_list_directory_with_sizes": "allow",
        "filesystem_directory_tree": "allow",
        "filesystem_search_files": "allow",
        "filesystem_get_file_info": "allow",
        "filesystem_list_allowed_directories": "allow",
        "filesystem_write_file": "ask",
        "filesystem_edit_file": "ask",
        "filesystem_create_directory": "allow",
        // Rest denied
        "octocode_*": "deny",
        "kubernetes_*": "deny",
        "obsidian_*": "deny",
        "drawio_*": "deny",
        "git_*": "deny",
        "sequentialthinking_*": "deny"
      },
      "prompt": "{file:./prompts/test.txt}"
    }
  },
  "disabled_providers": ["opencode"],
  "provider": {
    "github-copilot": {
      "blacklist": [
        // Officially retired models
        // Reference: https://docs.github.com/en/copilot/reference/ai-models/supported-models#model-retirement-history
        "gpt-4o", // not in current supported models list
        "gpt-5", // retired 2026-02-17
        "gpt-5.1", // closing down 2026-04-15
        "gpt-5.1-codex", // retired 2026-04-01
        "gpt-5.1-codex-max", // retired 2026-04-01
        "gpt-5.1-codex-mini", // retired 2026-04-01
        "gemini-3-pro-preview", // retired 2026-03-26
        "claude-opus-41", // retired 2026-02-17
        // Personal preference for "superseeded" models
        "claude-sonnet-4", // older Sonnet version
        "claude-sonnet-4.5", // older Sonnet version
        "claude-opus-4.5", // older Opus version
        "gpt-5.2", // older GPT-5 generation
        "gpt-5.2-codex" // older Codex variant
      ]
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "--prefer-offline", "@upstash/context7-mcp"],
      "enabled": true
    },
    "kubernetes": {
      "type": "local",
      "command": ["npx", "--prefer-offline", "kubernetes-mcp-server"],
      "enabled": true,
      "environment": {
        "KUBECONFIG": "{env:KUBECONFIG}"
      }
    },
    "obsidian": {
      "type": "local",
      "command": [
        "npx",
        "@bitbonsai/mcpvault@latest",
        "{env:HOME}/Documents/Obsidian Vault"
      ],
      "enabled": true
    },
    "drawio": {
      "type": "local",
      "command": ["npx", "--prefer-offline", "@drawio/mcp"],
      "enabled": true
    },
    "octocode": {
      "type": "local",
      "command": ["npx", "--prefer-offline", "octocode-mcp"],
      "enabled": true
    },
    "git": {
      "type": "local",
      "command": ["uvx", "mcp-server-git", "--repository", "."],
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "."],
      "enabled": true
    },
    "sequentialthinking": {
      "type": "local",
      "command": [
        "npx",
        "--prefer-offline",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    }
  }
}
