{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "username": "anokfireball",
  "plugin": [
    // dynamic context pruning
    "@tarquinen/opencode-dcp@latest",
    // terminal emulation for tools that require interactive sessions
    "opencode-pty",
    // background process management
    "@zenobius/opencode-background"
  ],
  "small_model": "{env:OPENCODE_MODEL_SMALL}",
  "default_agent": "research",
  "permission": {
    // Built-in tools
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git rev-parse*": "allow",
      "git remote*": "allow",
      "git ls-files*": "allow",
      "git blame*": "allow",
      "git reflog*": "allow",
      "git stash list*": "allow",
      "git tag*": "allow",
      "git shortlog*": "allow",
      "git describe*": "allow",
      "git config --get*": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "jq *": "allow",
      "yq *": "allow",
      "bat *": "allow",
      "eza *": "allow",
      "grep *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "cut *": "allow",
      "dirname *": "allow",
      "basename *": "allow",
      "realpath *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "cat *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "paste *": "allow",
      "tr *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "column *": "allow",
      "comm *": "allow",
      "diff *": "allow",
      "cmp *": "allow",
      "strings *": "allow",
      "md5 *": "allow",
      "shasum *": "allow",
      "sha256sum *": "allow"
    },
    "webfetch": "ask",
    "websearch": "deny",

    // PTY plugin tools
    "pty_*": "deny",

    // Background process plugin tools
    "createBackgroundProcess": "deny",
    "listBackgroundProcesss": "deny",
    "getBackgroundProcess": "deny",
    "killTasks": "deny",

    // Draw.io MCP tools
    "drawio_*": "deny"
  },
  "agent": {
    // Built-in agents override the global baseline only where they differ.
    "build": {
      "model": "{env:OPENCODE_MODEL_BUILD}",
      "permission": {
        // Built-in tools
        "edit": "allow",
        "webfetch": "allow",
        "bash": {
          "pytest*": "allow",
          "go test*": "allow",
          "go build*": "allow",
          "make *": "allow"
        },

        // PTY plugin tools
        "pty_*": "allow",

        // Background process plugin tools
        "createBackgroundProcess": "allow",
        "listBackgroundProcesss": "allow",
        "getBackgroundProcess": "allow",
        "killTasks": "allow",

        // Obsidian MCP tools
        "obsidian_*": "allow",
        "obsidian_read_note": "allow",
        "obsidian_list_directory": "allow",
        "obsidian_search_notes": "allow",
        "obsidian_read_multiple_notes": "allow",
        "obsidian_get_notes_info": "allow",
        "obsidian_get_frontmatter": "allow",
        "obsidian_get_vault_stats": "allow",
        "obsidian_list_all_tags": "allow",
        "obsidian_write_note": "ask",
        "obsidian_patch_note": "ask",
        "obsidian_update_frontmatter": "ask",

        // Kubernetes MCP tools
        "kubernetes_*": "deny",
        "kubernetes_configuration_contexts_list": "allow",
        "kubernetes_configuration_view": "allow",
        "kubernetes_namespaces_list": "allow",
        "kubernetes_pods_list": "allow",
        "kubernetes_pods_list_in_namespace": "allow",
        "kubernetes_pods_get": "allow",
        "kubernetes_pods_top": "allow",
        "kubernetes_pods_log": "allow",
        "kubernetes_events_list": "allow",
        "kubernetes_nodes_log": "allow",
        "kubernetes_nodes_top": "allow",
        "kubernetes_resources_list": "allow",
        "kubernetes_resources_get": "allow",

        // Draw.io MCP tools
        "drawio_*": "deny"
      }
    },
    "plan": {
      "model": "{env:OPENCODE_MODEL_PLAN}",
      // Upstream already restricts edit/bash to ask. Fine-grained MCP gates.
      "permission": {
        // Built-in tools
        "webfetch": "allow",
        "websearch": "ask",

        // Obsidian MCP tools
        "obsidian_*": "allow",
        "obsidian_read_note": "allow",
        "obsidian_list_directory": "allow",
        "obsidian_search_notes": "allow",
        "obsidian_read_multiple_notes": "allow",
        "obsidian_get_notes_info": "allow",
        "obsidian_get_frontmatter": "allow",
        "obsidian_get_vault_stats": "allow",
        "obsidian_list_all_tags": "allow",
        "obsidian_write_note": "ask",
        "obsidian_patch_note": "ask",

        // Kubernetes MCP tools
        // Kubernetes — read-only auto-allow, mutations deny
        "kubernetes_*": "deny",
        "kubernetes_configuration_contexts_list": "allow",
        "kubernetes_configuration_view": "allow",
        "kubernetes_pods_list": "allow",
        "kubernetes_pods_list_in_namespace": "allow",
        "kubernetes_pods_get": "allow",
        "kubernetes_pods_top": "allow",
        "kubernetes_pods_log": "allow",
        "kubernetes_events_list": "allow",
        "kubernetes_namespaces_list": "allow",
        "kubernetes_nodes_log": "allow",
        "kubernetes_nodes_top": "allow",
        "kubernetes_nodes_stats_summary": "allow",
        "kubernetes_resources_list": "allow",
        "kubernetes_resources_get": "allow",

        // Draw.io MCP tools
        "drawio_*": "ask"
      }
    },
    "general": {
      "model": "{env:OPENCODE_MODEL_GENERAL}",
      "permission": {
        // Built-in tools
        "webfetch": "allow",
        "websearch": "allow",

        // PTY plugin tools
        "pty_*": "ask",

        // Background process plugin tools
        "createBackgroundProcess": "ask",
        "listBackgroundProcesss": "allow",
        "getBackgroundProcess": "allow",
        "killTasks": "ask",

        // Obsidian MCP tools
        "obsidian_*": "ask",
        "obsidian_read_note": "allow",
        "obsidian_list_directory": "allow",
        "obsidian_search_notes": "allow",
        "obsidian_read_multiple_notes": "allow",
        "obsidian_get_notes_info": "allow",
        "obsidian_get_frontmatter": "allow",
        "obsidian_get_vault_stats": "allow",
        "obsidian_list_all_tags": "allow",

        // Kubernetes MCP tools
        "kubernetes_*": "deny",
        "kubernetes_configuration_contexts_list": "allow",
        "kubernetes_configuration_view": "allow",
        "kubernetes_namespaces_list": "allow",
        "kubernetes_pods_list": "allow",
        "kubernetes_pods_list_in_namespace": "allow",
        "kubernetes_pods_get": "allow",
        "kubernetes_pods_top": "allow",
        "kubernetes_pods_log": "allow",
        "kubernetes_events_list": "allow",
        "kubernetes_nodes_log": "allow",
        "kubernetes_nodes_top": "allow",
        "kubernetes_nodes_stats_summary": "allow",
        "kubernetes_resources_list": "allow",
        "kubernetes_resources_get": "allow",
        "kubernetes_pods_delete": "ask",
        "kubernetes_pods_exec": "ask",
        "kubernetes_pods_run": "ask",
        "kubernetes_resources_create_or_update": "ask",
        "kubernetes_resources_delete": "ask",
        "kubernetes_resources_scale": "ask"
      }
    },
    "explore": {
      "model": "{env:OPENCODE_MODEL_EXPLORE}",
      // Already read-only upstream. Fine-grained read access to MCPs.
      "permission": {
        // Built-in tools
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "skill": "deny",
        "webfetch": "deny",
        "external_directory": "deny",

        // Context7 MCP tools
        "context7_*": "deny",

        // Octocode MCP tools
        "octocode_*": "deny",

        // Sequential Thinking MCP tools
        "sequentialthinking_*": "deny",

        // Kubernetes MCP tools
        // Kubernetes — read-only recon
        "kubernetes_*": "deny",
        "kubernetes_configuration_contexts_list": "allow",
        "kubernetes_configuration_view": "allow",
        "kubernetes_pods_list": "allow",
        "kubernetes_pods_list_in_namespace": "allow",
        "kubernetes_pods_get": "allow",
        "kubernetes_pods_top": "allow",
        "kubernetes_pods_log": "allow",
        "kubernetes_events_list": "allow",
        "kubernetes_namespaces_list": "allow",
        "kubernetes_nodes_log": "allow",
        "kubernetes_nodes_top": "allow",
        "kubernetes_nodes_stats_summary": "allow",
        "kubernetes_resources_list": "allow",
        "kubernetes_resources_get": "allow",
        // Obsidian MCP tools
        // Not needed for fast recon
        "obsidian_*": "deny"
      }
    },
    "compaction": {
      "model": "{env:OPENCODE_MODEL_COMPACTION}",
      "permission": {
        "*": "deny"
      }
    },
    "title": {
      "model": "{env:OPENCODE_MODEL_TITLE}",
      "permission": {
        "*": "deny"
      }
    },
    "summary": {
      "model": "{env:OPENCODE_MODEL_SUMMARY}",
      "permission": {
        "*": "deny"
      }
    },
    "research": {
      "description": "Performs comprehensive research and analysis to answer questions about code, tools, frameworks, and project structure",
      "model": "{env:OPENCODE_MODEL_RESEARCH}",
      "mode": "primary",
      "temperature": 0.0,
      "permission": {
        // Built-in tools
        // Mutations — hard deny
        "edit": "deny",
        // Web access
        "webfetch": "allow",
        "websearch": "allow",

        // MCP tools
        // Obsidian MCP tools
        // Obsidian — read-only
        "obsidian_*": "deny",
        "obsidian_read_note": "allow",
        "obsidian_list_directory": "allow",
        "obsidian_search_notes": "allow",
        "obsidian_read_multiple_notes": "allow",
        "obsidian_get_notes_info": "allow",
        "obsidian_get_frontmatter": "allow",
        "obsidian_get_vault_stats": "allow",
        "obsidian_list_all_tags": "allow",

        // Kubernetes MCP tools
        // Kubernetes — read-only
        "kubernetes_*": "deny",
        "kubernetes_configuration_contexts_list": "allow",
        "kubernetes_configuration_view": "allow",
        "kubernetes_pods_list": "allow",
        "kubernetes_pods_list_in_namespace": "allow",
        "kubernetes_pods_get": "allow",
        "kubernetes_pods_top": "allow",
        "kubernetes_pods_log": "allow",
        "kubernetes_events_list": "allow",
        "kubernetes_namespaces_list": "allow",
        "kubernetes_nodes_log": "allow",
        "kubernetes_nodes_top": "allow",
        "kubernetes_resources_list": "allow",
        "kubernetes_resources_get": "allow",

        // Draw.io MCP tools
        "drawio_*": "deny"
      },
      "prompt": "{file:./prompts/research.txt}"
    },
    "review": {
      "description": "Performs in-depth code reviews focusing on correctness, security, maintainability, and architecture",
      "model": "{env:OPENCODE_MODEL_REVIEW}",
      "mode": "primary",
      "temperature": 0.1,
      "permission": {
        // Built-in tools
        // Mutations — hard deny
        "edit": "deny",
        // Web access
        "webfetch": "allow",

        // MCP tools
        // Obsidian MCP tools
        // No obsidian for code review
        "obsidian_*": "deny",

        // Kubernetes MCP tools
        "kubernetes_*": "deny",

        // Draw.io MCP tools
        "drawio_*": "deny"
      },
      "prompt": "{file:./prompts/review.txt}"
    },
    "ticket": {
      "description": "Generates well-structured ticket files from scenario descriptions and tasks",
      "model": "{env:OPENCODE_MODEL_TICKET}",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": {
        // Built-in tools
        // Ticket files live in the workspace, not Obsidian.
        "bash": {
          "*": "deny",
          "mkdir*": "allow"
        },
        // No subagent chaining or skills
        "task": "deny",
        "skill": "deny",
        // Web lookups are unnecessary for the documented workflow.
        "webfetch": "deny",
        "external_directory": "deny",
        "doom_loop": "deny",

        // Context7 MCP tools
        "context7_*": "deny",

        // Obsidian MCP tools
        // Everything else denied.
        "obsidian_*": "deny",

        // Kubernetes MCP tools
        "kubernetes_*": "deny",

        // Draw.io MCP tools
        "drawio_*": "deny"
      },
      "prompt": "{file:./prompts/ticket.txt}"
    },
    "docs": {
      "description": "Creates comprehensive documentation including inline code comments, API docs, and architectural overviews",
      "model": "{env:OPENCODE_MODEL_DOCS}",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": {
        // Built-in tools
        // Bash — mkdir for doc dirs, everything else denied.
        "bash": {
          "*": "deny",
          "mkdir*": "allow"
        },
        // No subagent chaining or skills
        "task": "deny",
        "skill": "deny",
        // Web — ask (may need external API docs)
        "external_directory": "deny",
        "doom_loop": "deny",

        // Draw.io MCP tools
        "drawio_*": "allow",

        // Obsidian MCP tools
        // Obsidian — read + controlled writes
        "obsidian_*": "deny",
        "obsidian_read_note": "allow",
        "obsidian_list_directory": "allow",
        "obsidian_search_notes": "allow",
        "obsidian_read_multiple_notes": "allow",
        "obsidian_get_notes_info": "allow",
        "obsidian_get_frontmatter": "allow",
        "obsidian_get_vault_stats": "allow",
        "obsidian_list_all_tags": "allow",
        "obsidian_write_note": "allow",
        "obsidian_patch_note": "allow",
        "obsidian_update_frontmatter": "ask",

        // Kubernetes MCP tools
        // Rest denied
        "kubernetes_*": "deny"
      },
      "prompt": "{file:./prompts/docs.txt}"
    },
    "test": {
      "description": "Analyzes codebases to design appropriate test strategies, reasons about test necessity and type selection, and implements comprehensive test suites following language-specific best practices",
      "model": "{env:OPENCODE_MODEL_TEST}",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": {
        // Built-in tools
        // Bash — test runners + mkdir explicitly allowed
        "bash": {
          "npm test*": "allow",
          "npx jest*": "allow",
          "npx vitest*": "allow",
          "pytest*": "allow",
          "go test*": "allow",
          "make test*": "allow",
          "mkdir*": "allow"
        },
        // No subagent chaining or skills
        "task": "deny",
        "skill": "deny",
        "external_directory": "deny",
        "doom_loop": "deny",

        // PTY plugin tools
        "pty_*": "ask",

        // Kubernetes MCP tools
        // Rest denied
        "kubernetes_*": "deny",

        // Obsidian MCP tools
        "obsidian_*": "deny",

        // Draw.io MCP tools
        "drawio_*": "deny"
      },
      "prompt": "{file:./prompts/test.txt}"
    }
  },
  "disabled_providers": ["opencode"],
  "provider": {
    "github-copilot": {
      "blacklist": [
        // Officially retired models
        // Reference: https://docs.github.com/en/copilot/reference/ai-models/supported-models#model-retirement-history
        "gpt-4o", // not in current supported models list
        "gpt-5", // retired 2026-02-17
        "gpt-5.1", // closing down 2026-04-15
        "gpt-5.1-codex", // retired 2026-04-01
        "gpt-5.1-codex-max", // retired 2026-04-01
        "gpt-5.1-codex-mini", // retired 2026-04-01
        "gemini-3-pro-preview", // retired 2026-03-26
        "claude-opus-41", // retired 2026-02-17
        // Personal preference for "superseeded" models
        "claude-sonnet-4", // older Sonnet version
        "claude-sonnet-4.5", // older Sonnet version
        "claude-opus-4.5", // older Opus version
        "gpt-5.2", // older GPT-5 generation
        "gpt-5.2-codex" // older Codex variant
      ]
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "--prefer-offline", "@upstash/context7-mcp"],
      "enabled": true
    },
    "kubernetes": {
      "type": "local",
      "command": ["npx", "--prefer-offline", "kubernetes-mcp-server"],
      "enabled": true,
      "environment": {
        "KUBECONFIG": "{env:KUBECONFIG}"
      }
    },
    "obsidian": {
      "type": "local",
      "command": [
        "npx",
        "@bitbonsai/mcpvault@latest",
        "{env:HOME}/Documents/Obsidian Vault"
      ],
      "enabled": true
    },
    "drawio": {
      "type": "local",
      "command": ["npx", "--prefer-offline", "@drawio/mcp"],
      "enabled": true
    },
    "octocode": {
      "type": "local",
      "command": ["npx", "--prefer-offline", "octocode-mcp"],
      "enabled": true
    },
    "sequentialthinking": {
      "type": "local",
      "command": [
        "npx",
        "--prefer-offline",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    }
  }
}
